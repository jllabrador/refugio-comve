# ── Clerk (autenticación) ────────────────────────────────────
# Obtener en: https://dashboard.clerk.com → tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX

# Rutas de Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Resend (email transaccional) ─────────────────────────────
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=no-reply@refugio.com.ve

# ── WhatsApp Business API (Meta) ─────────────────────────────
# Cuenta Meta Business INDEPENDIENTE (no Galait)
WHATSAPP_API_TOKEN=XXXXXXXXXXXXXXXX
WHATSAPP_PHONE_NUMBER_ID=XXXXXXXXXXXXXXXX
WHATSAPP_VERIFY_TOKEN=refugio_webhook_secret_2024

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://refugio.com.ve
APP_ENV=development

# ── Cloudflare (para Workers locales con wrangler dev) ───────
# No se necesita aquí — wrangler usa wrangler.toml + secrets
